---
import Layout from '../../layouts/Layout.astro'
import '../../styles/globals.css'
import { getCollection } from 'astro:content'

const docs = (await getCollection('docs')).sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
---

<Layout title="Amiga x Shaun Docs">
  <main class="mx-auto max-w-5xl px-6 py-12">
    <header class="mb-10">
      <p class="text-sm uppercase tracking-wide text-slate-500">Shared docs</p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950">Amiga x Shaun Documentation</h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-600">
        A shared documentation home for projects, operating patterns, workflows, setup notes, and decisions.
      </p>
    </header>

    <section class="grid gap-4">
      {docs.map((doc) => (
        <a href={`/docs/${doc.id.replace(/\.md$/, '')}`} class="block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-slate-300 hover:shadow-md">
          <div class="text-sm text-slate-500">{doc.data.section || 'Docs'}</div>
          <h2 class="mt-1 text-2xl font-semibold text-slate-950">{doc.data.title}</h2>
          {doc.data.description && <p class="mt-2 text-slate-600">{doc.data.description}</p>}
          {doc.data.updated && <p class="mt-3 text-sm text-slate-400">Updated {doc.data.updated}</p>}
        </a>
      ))}
    </section>
  </main>
</Layout>
