---
import Layout from '../../layouts/Layout.astro'
import '../../styles/globals.css'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map((doc) => ({
    params: { slug: doc.id.replace(/\.md$/, '') },
    props: { doc },
  }))
}

const { doc } = Astro.props
const { Content } = await render(doc)
---

<Layout title={`${doc.data.title} · Amiga x Shaun Docs`}>
  <main class="mx-auto max-w-4xl px-6 py-12">
    <nav class="mb-8 text-sm text-slate-500">
      <a href="/docs" class="hover:text-slate-900">Docs</a>
      <span class="mx-2">/</span>
      <span>{doc.data.title}</span>
    </nav>

    <article class="prose prose-slate max-w-none">
      <header class="mb-10 not-prose">
        <div class="text-sm uppercase tracking-wide text-slate-500">{doc.data.section || 'Docs'}</div>
        <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950">{doc.data.title}</h1>
        {doc.data.description && <p class="mt-3 text-lg text-slate-600">{doc.data.description}</p>}
        {doc.data.updated && <p class="mt-3 text-sm text-slate-500">Updated {doc.data.updated}</p>}
      </header>
      <Content />
    </article>
  </main>
</Layout>
